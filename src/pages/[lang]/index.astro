---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TermCard from '../../components/TermCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { t, LANGS, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const termes = await getCollection('termes');

const sorted = termes.sort((a, b) => {
  const ta = (lang === 'fr' ? a.data.terme_fr : a.data.terme_en).toLowerCase();
  const tb = (lang === 'fr' ? b.data.terme_fr : b.data.terme_en).toLowerCase();
  return ta.localeCompare(tb, lang);
});

function initial(entry: (typeof sorted)[number]): string {
  const nom = lang === 'fr' ? entry.data.terme_fr : entry.data.terme_en;
  return nom
    .charAt(0)
    .toUpperCase()
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '');
}

const lettres = [...new Set(sorted.map(initial))];
---

<Base
  lang={lang}
  title={t(lang, 'site.title')}
  description={t(lang, 'hero.lede').slice(0, 155)}
  altPath={`/${lang === 'fr' ? 'en' : 'fr'}/`}
>
  <section class="hero">
    <div class="container">
      <span class="hero-eyebrow">{t(lang, 'hero.eyebrow')} · {sorted.length} {lang === 'fr' ? 'définitions' : 'definitions'}</span>
      <h1>{t(lang, 'hero.title.before')}<em>{t(lang, 'hero.title.em')}</em></h1>
      <p class="hero-lede">{t(lang, 'hero.lede')}</p>
    </div>
  </section>

  <FilterBar lang={lang} lettres={lettres} />

  <section class="glossary">
    <div class="container">
      <div class="glossary-count">
        <strong id="term-count">{sorted.length}</strong>{' '}{t(lang, 'count.terms')}
      </div>
      <div class="term-list" id="term-list">
        {
          sorted.map((entry, i) => (
            <>
              {(i === 0 || initial(entry) !== initial(sorted[i - 1])) && (
                <div class="letter-divider" id={`lettre-${initial(entry)}`}>
                  {initial(entry)}
                </div>
              )}
              <TermCard entry={entry} lang={lang} />
            </>
          ))
        }
      </div>
      <div class="empty-state" id="empty-state">
        <h3>{t(lang, 'search.empty.title')}</h3>
        <p>{t(lang, 'search.empty.body')}</p>
        <button class="filter-btn" id="reset-filters" style="margin-top: 18px;">
          {t(lang, 'search.reset')}
        </button>
      </div>
    </div>
  </section>
</Base>

<style>
  .empty-state {
    text-align: center;
    padding: 80px 0;
    color: var(--muted);
    display: none;
  }

  .empty-state.visible {
    display: block;
  }

  .empty-state h3 {
    font-size: 22px;
    margin-bottom: 12px;
    color: var(--cream);
  }

  .letter-divider {
    scroll-margin-top: 90px;
  }
</style>
